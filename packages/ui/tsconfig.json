{
  "extends": "@erp/config/tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "references": [
    { "path": "../design-tokens" },
    { "path": "../contracts" },
    { "path": "../utils" }
  ],
  "include": ["src/**/*"],
