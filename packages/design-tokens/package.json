{
  "name": "@erp/design-tokens",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./css": "./dist/css/tokens.css",
    "./tailwind.css": "./dist/tailwind/preset.css",
    "./tailwind": {
      "types": "./dist/tailwind/preset.d.ts",
      "default": "./dist/tailwind/preset.js"
    }
  },
  "scripts": {
    "build": "tsc --build && tsx src/build-tokens.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@erp/config": "workspace:*",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "style-dictionary": "^4.3.0",
    "tsx": "^4.23.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
