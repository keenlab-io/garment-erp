{
  "name": "@erp/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "echo \"no tests yet\" && exit 0",
    "db:generate": "tsc --build && drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:seed": "tsx src/seed/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@erp/utils": "workspace:*",
    "argon2": "^0.44.0",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@erp/config": "workspace:*",
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.17.0",
    "tsx": "^4.23.0",
    "typescript": "^5.7.2"
  }
}
