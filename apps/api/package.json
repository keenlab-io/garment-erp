{
  "name": "@erp/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:migrate": "pnpm --filter @erp/db db:migrate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3",
    "@aws-sdk/s3-request-presigner": "^3",
    "@erp/contracts": "workspace:*",
    "@erp/db": "workspace:*",
    "@erp/utils": "workspace:*",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/event-emitter": "^2.1.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/platform-socket.io": "^10.4.15",
    "@nestjs/websockets": "^10.4.15",
    "@ts-rest/core": "^3.51.0",
    "@ts-rest/nest": "^3.51.0",
    "argon2": "^0.44.0",
    "bullmq": "^5",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "ioredis": "^5",
    "postgres": "^3.4.9",
    "puppeteer": "^24",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@erp/config": "workspace:*",
    "@nestjs/cli": "^10.4.9",
    "@swc/core": "^1.15.43",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.17.0",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.4",
    "tsx": "^4.23.0",
    "typescript": "^5.7.2",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.9"
  }
